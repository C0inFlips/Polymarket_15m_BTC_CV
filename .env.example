# ── Polymarket (execution venue) ─────────────────────────────────────────────
# Wallet private key that signs CLOB orders (EIP-712). NEVER commit the real
# value — copy this file to .env.local and fill it in there.
POLYMARKET_PRIVATE_KEY=YOUR_POLYMARKET_WALLET_PRIVATE_KEY

# Funder address — the wallet that actually holds funds/positions. For
# website-created accounts this is the profile "Address … For API use only"
# (deposit wallet). Leave empty for a raw EOA.
POLYMARKET_PROXY_ADDRESS=YOUR_POLYMARKET_PROXY_ADDRESS

# Signature type: 0=EOA, 1=legacy Magic proxy, 2=legacy browser proxy,
# 3=deposit wallet (POLY_1271 — current website accounts).
# Defaults: 3 when PROXY_ADDRESS is set, else 0.
# POLYMARKET_SIGNATURE_TYPE=3

# Optional pre-derived L2 API creds; when absent they are derived from the
# wallet key at startup.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Optional host overrides.
# POLYMARKET_HOST=https://clob.polymarket.com
# POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
# POLYMARKET_DATA_HOST=https://data-api.polymarket.com
# POLYMARKET_SITE_HOST=https://polymarket.com

# ── ChainVector (sole derived-signals provider) ──────────────────────────────
# API key from https://chainvector.com (looks like cv_live_...).
# Powers: probability engine (terminal P(above) at exact close_ts), futures
# momentum scorecard + lead-lag feed, prediction quote stability/edge,
# liquidation cascade risk & heatmap, order flow, funding, whale pressure,
# regime/volatility/risk-index context, and the 1m candles the Markov stack
# runs on. Without it the daemon still runs, but every ChainVector-backed
# gate fails open and the candle fetch fails (Markov needs candles).
CHAINVECTOR_API_KEY=YOUR_CHAINVECTOR_API_KEY

# Optional: override the ChainVector API base URL.
# CHAINVECTOR_BASE=https://chainvector.com/api/v1

# ── Runtime (optional) ───────────────────────────────────────────────────────
# Writable directory for logs / audit JSONL / caches. If unset, the daemon
# picks the first writable of: package dir -> ~/.polymarket_btc_15m_cv -> tmp.
# Set this in containers where the package dir is root-owned.
# BTC15M_DATA_DIR=/data/polymarket_btc_15m_cv
